# Docker Compose Environment Configuration
# For containerized development with Docker Compose

# =============================================================================
# API SERVICE ENDPOINTS - Docker Compose Services
# =============================================================================
VITE_API_USER_SERVICE=/api
VITE_API_BLOG_SERVICE=/api
VITE_API_FILE_SERVICE=/api

# =============================================================================
# VITE DEVELOPMENT PROXY CONFIGURATION
# =============================================================================
VITE_BACKEND_HOST=localhost
VITE_BACKEND_USER_PORT=9001
VITE_BACKEND_BLOG_PORT=8083
VITE_BACKEND_FILE_PORT=8085

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================
VITE_APP_TITLE=Blog Management System - Docker
VITE_ENV=docker

# =============================================================================
# DOCKER COMPOSE NOTES
# =============================================================================
# This configuration is for Docker Compose development where:
# 1. All services run in containers
# 2. NGINX routes all API calls to appropriate backends
# 3. Services use different ports to avoid conflicts
# 4. Frontend uses proxy to communicate with backends