# Development Environment Configuration
# For local development with Spring Boot services

# =============================================================================
# API SERVICE ENDPOINTS - Local Spring Boot Services
# =============================================================================
VITE_API_USER_SERVICE=http://localhost:8081/api
VITE_API_BLOG_SERVICE=http://localhost:8082/api
VITE_API_FILE_SERVICE=http://localhost:8083/api

# =============================================================================
# VITE DEVELOPMENT PROXY CONFIGURATION
# =============================================================================
VITE_BACKEND_HOST=localhost
VITE_BACKEND_USER_PORT=8081
VITE_BACKEND_BLOG_PORT=8082
VITE_BACKEND_FILE_PORT=8083

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================
VITE_APP_TITLE=Blog Management System - Development
VITE_ENV=development

# =============================================================================
# DEVELOPMENT NOTES
# =============================================================================
# This configuration is for local development where:
# 1. Backend services run with 'mvn spring-boot:run'
# 2. Frontend runs with 'npm run dev'
# 3. All services communicate via localhost
# 4. Database runs via Docker Compose