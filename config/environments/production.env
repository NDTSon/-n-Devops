# Production Environment Configuration
# For production deployment with proper domain configuration

# =============================================================================
# API SERVICE ENDPOINTS - Production URLs
# =============================================================================
# Option 1: Single domain with path routing (recommended)
VITE_API_USER_SERVICE=https://api.blogplatform.example.com/user
VITE_API_BLOG_SERVICE=https://api.blogplatform.example.com/blog
VITE_API_FILE_SERVICE=https://api.blogplatform.example.com/file

# Option 2: Subdomain routing (alternative)
# VITE_API_USER_SERVICE=https://user-api.blogplatform.example.com/api
# VITE_API_BLOG_SERVICE=https://blog-api.blogplatform.example.com/api
# VITE_API_FILE_SERVICE=https://file-api.blogplatform.example.com/api

# =============================================================================
# VITE PROXY CONFIGURATION (not used in production build)
# =============================================================================
VITE_BACKEND_HOST=api.blogplatform.example.com
VITE_BACKEND_USER_PORT=443
VITE_BACKEND_BLOG_PORT=443
VITE_BACKEND_FILE_PORT=443

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================
VITE_APP_TITLE=Blog Management System
VITE_ENV=production

# =============================================================================
# PRODUCTION NOTES
# =============================================================================
# This configuration is for production deployment where:
# 1. All services use HTTPS with proper SSL certificates
# 2. Services are behind load balancer/ingress controller
# 3. Replace 'blogplatform.example.com' with your actual domain
# 4. Ensure CORS is properly configured for your domain
# 5. Use environment-specific secrets management