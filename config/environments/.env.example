# Blog Platform Environment Configuration Template
# Copy this file and rename to match your environment (development.env, production.env, etc.)
# Fill in the appropriate values for your deployment scenario

# =============================================================================
# API SERVICE ENDPOINTS
# =============================================================================
VITE_API_USER_SERVICE=http://localhost:8081/api
VITE_API_BLOG_SERVICE=http://localhost:8082/api
VITE_API_FILE_SERVICE=http://localhost:8083/api

# =============================================================================
# VITE DEVELOPMENT PROXY CONFIGURATION
# Used only during development with 'npm run dev'
# =============================================================================
VITE_BACKEND_HOST=localhost
VITE_BACKEND_USER_PORT=8081
VITE_BACKEND_BLOG_PORT=8082
VITE_BACKEND_FILE_PORT=8083

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================
VITE_APP_TITLE=Blog Management System
VITE_ENV=development

# =============================================================================
# DEPLOYMENT SCENARIOS
# =============================================================================

# Scenario 1: Local Development (Spring Boot services)
# VITE_API_USER_SERVICE=http://localhost:8081/api
# VITE_API_BLOG_SERVICE=http://localhost:8082/api
# VITE_API_FILE_SERVICE=http://localhost:8083/api

# Scenario 2: Docker Compose (all services containerized)
# VITE_API_USER_SERVICE=/api
# VITE_API_BLOG_SERVICE=/api
# VITE_API_FILE_SERVICE=/api
# VITE_BACKEND_HOST=localhost
# VITE_BACKEND_USER_PORT=9001
# VITE_BACKEND_BLOG_PORT=8083
# VITE_BACKEND_FILE_PORT=8085

# Scenario 3: Kubernetes (port-forward for development)
# VITE_API_USER_SERVICE=http://localhost:8081/api
# VITE_API_BLOG_SERVICE=http://localhost:8082/api
# VITE_API_FILE_SERVICE=http://localhost:8083/api

# Scenario 4: Production (with domain)
# VITE_API_USER_SERVICE=https://api.yourdomain.com/user
# VITE_API_BLOG_SERVICE=https://api.yourdomain.com/blog
# VITE_API_FILE_SERVICE=https://api.yourdomain.com/file

# Scenario 5: Production (microservices with subdomains)
# VITE_API_USER_SERVICE=https://user-api.yourdomain.com/api
# VITE_API_BLOG_SERVICE=https://blog-api.yourdomain.com/api
# VITE_API_FILE_SERVICE=https://file-api.yourdomain.com/api