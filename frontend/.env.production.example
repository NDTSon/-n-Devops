# Frontend Environment Configuration - PRODUCTION
# Use this file for production deployment

# ==============================================================
# PRODUCTION SERVER CONFIGURATION
# ==============================================================
# Production API URL (HTTPS recommended)
VITE_API_URL=https://yourdomain.com/api

# Or if API is on subdomain
# VITE_API_URL=https://api.yourdomain.com/api

# App Configuration
VITE_APP_TITLE=Blog Management System
VITE_ENV=production

# ==============================================================
# DEPLOYMENT INSTRUCTIONS:
# ==============================================================
# 1. Update VITE_API_URL with your production domain
# 2. Ensure API Gateway is accessible at that URL
# 3. Build with: npm run build
# 4. Deploy dist/ folder to your web server
# 5. Configure web server (nginx/apache) to serve React app
# ==============================================================
