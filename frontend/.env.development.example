# Frontend Environment Configuration - DEVELOPMENT SERVER
# Uncomment and use this file for development server deployment

# ==============================================================
# DEVELOPMENT SERVER CONFIGURATION
# ==============================================================
# Uncomment the line below when deploying to dev server
# VITE_API_URL=http://dev.yourdomain.com:9000/api

# If using subdomain for API
# VITE_API_URL=http://api-dev.yourdomain.com/api

# If using same domain with different port
# VITE_API_URL=http://dev.yourdomain.com/api

# ==============================================================
# CURRENT: LOCAL DEVELOPMENT (default)
# ==============================================================
VITE_API_URL=http://localhost:9000/api

# App Configuration
VITE_APP_TITLE=Blog Management System - Development
VITE_ENV=development

# ==============================================================
# DEPLOYMENT INSTRUCTIONS:
# ==============================================================
# 1. Copy this file to .env.development
# 2. Uncomment the VITE_API_URL for your dev server
# 3. Update the domain to match your dev server
# 4. Build with: npm run build
# 5. Deploy dist/ folder to your web server
# ==============================================================
