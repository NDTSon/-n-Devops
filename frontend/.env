# Frontend Environment Variables Template
# Copy this file to .env.local for local development

# ==============================================================
# API CONFIGURATION
# ==============================================================
# Local Development (default)
VITE_API_URL=http://localhost:9000/api

# Development Server (uncomment when deploying to dev server)
# VITE_API_URL=http://dev.yourdomain.com:9000/api
# VITE_API_URL=http://api-dev.yourdomain.com/api

# Production Server (uncomment when deploying to production)
# VITE_API_URL=https://yourdomain.com/api
# VITE_API_URL=https://api.yourdomain.com/api

# ==============================================================
# APP CONFIGURATION
# ==============================================================
VITE_APP_TITLE=Blog Management System
VITE_ENV=local

# ==============================================================
# USAGE INSTRUCTIONS
# ==============================================================
# 
# For Local Development:
# 1. Copy this file: cp .env.example .env.local
# 2. Keep VITE_API_URL=http://localhost:9000/api
# 3. Make sure API Gateway is running on port 9000
# 4. Run: npm run dev
#
# For Development Server:
# 1. Copy this file: cp .env.example .env.development
# 2. Uncomment and update dev server VITE_API_URL
# 3. Update domain to match your dev server
# 4. Run: npm run build
# 5. Deploy dist/ folder
#
# For Production Server:
# 1. Copy this file: cp .env.example .env.production
# 2. Uncomment and update production VITE_API_URL
# 3. Use HTTPS for production
# 4. Run: npm run build
# 5. Deploy dist/ folder to production server
#
# ==============================================================
# NOTES
# ==============================================================
# - Vite automatically loads .env files based on mode
# - .env.local is loaded in development mode (npm run dev)
# - .env.production is loaded in production build (npm run build)
# - .env.development is loaded with --mode development
# - All VITE_ prefixed variables are exposed to the app
# - Never commit .env.local or .env.production with sensitive data
# ==============================================================
